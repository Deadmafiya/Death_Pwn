# deathPWN — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Provider A (Primary) ─────────────────────────────────
DEATHPWN_PROVIDER_A_URL=
DEATHPWN_PROVIDER_A_KEY=
DEATHPWN_PROVIDER_A_MODEL=

# ── Provider B (Fallback) ─────────────────────────────────
DEATHPWN_PROVIDER_B_URL=
DEATHPWN_PROVIDER_B_KEY=
DEATHPWN_PROVIDER_B_MODEL=

# ── Optional ──────────────────────────────────────────────
# Shell for subprocess execution (default: $SHELL → /bin/sh)
# DEATHPWN_SHELL=/bin/bash

# Goal-completion loop safety cap (default: 12)
# DEATHPWN_MAX_GOAL_STEPS=12

# Max AI-driven argv corrections per command (default: 2)
# DEATHPWN_MAX_CORRECTIONS=2

# HTTP request timeout in seconds (default: 30)
# DEATHPWN_HTTP_TIMEOUT_SECS=30

# Root directory for command output artifacts (default: $XDG_DATA_HOME/deathpwn/)
# DEATHPWN_ARTIFACTS_DIR=
